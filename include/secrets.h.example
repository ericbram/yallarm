#pragma once

// Local WiFi credentials for development. Copy this file to `secrets.h`
// (which is gitignored) and fill in your real values. The firmware will
// auto-connect on boot using these and skip the captive portal.
//
// Leave them empty / delete the file entirely to fall back to the
// WiFiManager captive portal flow.

#define WIFI_SSID      "YourNetworkName"
#define WIFI_PASSWORD  "YourPassword"
